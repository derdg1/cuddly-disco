# ══════════════════════════════════════════════════════════════════════════════
# PrePress Studio – Umgebungsvariablen
#
# Kopiere diese Datei nach .env und passe die Werte an.
# Für Portainer: Umgebungsvariablen direkt im Stack-Editor eingeben.
# ══════════════════════════════════════════════════════════════════════════════

# ── Ports (öffentlich erreichbar) ─────────────────────────────────────────────
# Frontend (nginx) auf Port 80, oder z.B. 8080 wenn Port 80 belegt ist
APP_PORT=80

# Backend API – normalerweise nur intern nötig, wenn Reverse-Proxy vorhanden
API_PORT=8000

# ── Sicherheit ────────────────────────────────────────────────────────────────
# WICHTIG: In Produktion auf einen langen Zufallswert ändern!
# Generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-random-hex-32-chars

# ── Upload-Limits ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500

# ── Docker Image Registry (optional) ─────────────────────────────────────────
# Leer lassen für lokalen Build.
# Für GHCR (GitHub Container Registry): REGISTRY=ghcr.io/derdg1/cuddly-disco/
REGISTRY=

# Image-Tag (Standard: latest) – wird von CI/CD automatisch gesetzt (sha-xxxxxx)
TAG=latest

# ── CI/CD – Portainer Webhook URLs ───────────────────────────────────────────
# In GitHub Actions Secrets hinterlegen (Settings → Secrets → Actions):
#   PORTAINER_WEBHOOK_BACKEND  → Portainer → Services → backend → Webhooks → URL kopieren
#   PORTAINER_WEBHOOK_FRONTEND → Portainer → Services → frontend → Webhooks → URL kopieren
#
# Automatisches Deploy aktivieren:
#   GitHub → Settings → Variables → New variable
#   Name: PORTAINER_ENABLED   Value: true
