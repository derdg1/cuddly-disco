# ══════════════════════════════════════════════════════════════════════════════
# PrePress Studio – Umgebungsvariablen
#
# Kopiere diese Datei nach .env und passe die Werte an.
# Für Portainer: Umgebungsvariablen direkt im Stack-Editor eingeben.
# ══════════════════════════════════════════════════════════════════════════════

# ── Ports (öffentlich erreichbar) ─────────────────────────────────────────────
# Frontend (nginx) auf Port 80, oder z.B. 8080 wenn Port 80 belegt ist
APP_PORT=80

# Backend API – normalerweise nur intern nötig, wenn Reverse-Proxy vorhanden
API_PORT=8000

# ── Sicherheit ────────────────────────────────────────────────────────────────
# WICHTIG: In Produktion auf einen langen Zufallswert ändern!
# Generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-random-hex-32-chars

# ── Upload-Limits ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500

# ── Docker Image Registry (optional) ─────────────────────────────────────────
# Leer lassen für lokalen Build.
# Für private Registry: REGISTRY=registry.example.com/
REGISTRY=

# Image-Tag (Standard: latest)
TAG=latest
